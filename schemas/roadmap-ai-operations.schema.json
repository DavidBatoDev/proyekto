{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prodigy.local/schemas/roadmap-ai-operations.schema.json",
  "title": "Roadmap AI Operations",
  "description": "Canonical per-operation validation contract shared between the Python agent planner, the NestJS backend DTO, and the planner tool JSON schema shown to the LLM. Changes here must be mirrored by npm run check:roadmap-ai-schema.",
  "definitions": {
    "operation_requirements": {
      "description": "Per-op required-identifier policy. `target` means the operation addresses an existing node via node_id XOR node_ref. `parent` means the operation creates a node under a parent via parent_id XOR parent_ref. `data_title` means data.title is required.",
      "type": "object",
      "properties": {
        "add_epic": {
          "target": null,
          "parent": false,
          "data_title": true
        },
        "add_feature": {
          "target": null,
          "parent": true,
          "data_title": true
        },
        "add_task": {
          "target": null,
          "parent": true,
          "data_title": true
        },
        "update_node": {
          "target": true,
          "parent": false,
          "data_title": false
        },
        "move_node": {
          "target": true,
          "parent": false,
          "data_title": false
        },
        "delete_node": {
          "target": true,
          "parent": false,
          "data_title": false
        },
        "mark_status": {
          "target": true,
          "parent": false,
          "data_title": false
        },
        "shift_dates": {
          "target": true,
          "parent": false,
          "data_title": false
        }
      }
    }
  },
  "type": "object",
  "required": ["operations"],
  "properties": {
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["op"],
        "properties": {
          "op": {
            "type": "string",
            "enum": [
              "add_epic",
              "add_feature",
              "add_task",
              "update_node",
              "move_node",
              "delete_node",
              "mark_status",
              "shift_dates"
            ]
          },
          "node_type": {
            "type": "string",
            "enum": ["roadmap", "epic", "feature", "task"]
          },
          "node_id": { "type": "string" },
          "node_ref": { "type": "string" },
          "parent_id": { "type": "string" },
          "parent_ref": { "type": "string" },
          "new_parent_id": { "type": "string" },
          "new_parent_ref": { "type": "string" },
          "temp_id": { "type": "string" },
          "position": { "type": "integer", "minimum": 0 },
          "patch": { "type": "object" },
          "status": { "type": "string" },
          "delta_days": { "type": "integer" },
          "scope": { "type": "object" },
          "data": { "type": "object" }
        },
        "allOf": [
          {
            "if": { "properties": { "op": { "const": "add_epic" } }, "required": ["op"] },
            "then": { "required": ["data"] }
          },
          {
            "if": { "properties": { "op": { "const": "add_feature" } }, "required": ["op"] },
            "then": {
              "required": ["data"],
              "oneOf": [
                { "required": ["parent_id"] },
                { "required": ["parent_ref"] }
              ]
            }
          },
          {
            "if": { "properties": { "op": { "const": "add_task" } }, "required": ["op"] },
            "then": {
              "required": ["data"],
              "oneOf": [
                { "required": ["parent_id"] },
                { "required": ["parent_ref"] }
              ]
            }
          },
          {
            "if": { "properties": { "op": { "const": "update_node" } }, "required": ["op"] },
            "then": {
              "oneOf": [
                { "required": ["node_id"] },
                { "required": ["node_ref"] }
              ]
            }
          },
          {
            "if": { "properties": { "op": { "const": "delete_node" } }, "required": ["op"] },
            "then": {
              "oneOf": [
                { "required": ["node_id"] },
                { "required": ["node_ref"] }
              ]
            }
          },
          {
            "if": { "properties": { "op": { "const": "move_node" } }, "required": ["op"] },
            "then": {
              "oneOf": [
                { "required": ["node_id"] },
                { "required": ["node_ref"] }
              ]
            }
          },
          {
            "if": { "properties": { "op": { "const": "mark_status" } }, "required": ["op"] },
            "then": {
              "oneOf": [
                { "required": ["node_id"] },
                { "required": ["node_ref"] }
              ]
            }
          },
          {
            "if": { "properties": { "op": { "const": "shift_dates" } }, "required": ["op"] },
            "then": {
              "oneOf": [
                { "required": ["node_id"] },
                { "required": ["node_ref"] }
              ]
            }
          }
        ]
      }
    }
  }
}
