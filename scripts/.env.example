# Resolve lookup benchmark environment
# Copy to scripts/.env (or backend/.env / repo .env) and update values.

BENCH_API_BASE="http://localhost:3000"
BENCH_ROADMAP_ID="<roadmap_id>"
BENCH_AUTH_TOKEN="<jwt_without_Bearer_prefix>"

# Optional benchmark tuning
# BENCH_NODE_TYPE=epic
# BENCH_NODE_TYPES=epic,feature,task
# BENCH_QUERY_PROFILE=mixed
# BENCH_QUERIES=Platform Foundation|Roadmap JSON Editor
# BENCH_HIT_REPEATS=5
# BENCH_PARALLEL=10
# BENCH_TIMEOUT_MS=15000
# BENCH_ASSERT_WARM_P95_MS=100
# BENCH_REDIS_CHAOS=false

# Optional roadmap AI commit benchmark tuning
# BENCH_COMMIT_ITERATIONS=8
# BENCH_COMMIT_WARMUP=1
# BENCH_COMMIT_TIMEOUT_MS=20000
# BENCH_COMMIT_NODE_TYPE=epic
# BENCH_COMMIT_NODE_ID=<optional_node_uuid>
# BENCH_COMMIT_INCLUDE_TIMELINE=false
# BENCH_COMMIT_INCLUDE_ROADMAP_MODES=true,false
# BENCH_ASSERT_LEAN_P95_MS=350
# BENCH_ASSERT_P95_SAVINGS_MS=30
