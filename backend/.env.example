# NestJS Backend Environment Variables

# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Server Configuration
PORT=3001
NODE_ENV=development
REQUEST_TIMEOUT_MS=25000
SLOW_REQUEST_THRESHOLD_MS=1500
SUPABASE_FETCH_TIMEOUT_MS=12000

# CORS
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Roadmap AI (performance/safety)
ROADMAP_AI_AUTHZ_CACHE_TTL_MS=10000
ROADMAP_AI_AUTHZ_CACHE_MAX_ENTRIES=5000
ROADMAP_AI_AUTHZ_CACHE_VERSION=v1
