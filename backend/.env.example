# NestJS Backend Environment Variables

# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Server Configuration
PORT=3001
NODE_ENV=development
REQUEST_TIMEOUT_MS=25000
SLOW_REQUEST_THRESHOLD_MS=1500
SUPABASE_FETCH_TIMEOUT_MS=12000
ENABLE_CLOUD_TRACE=false
CLOUD_TRACE_SAMPLE_RATIO=0.1
OTEL_SERVICE_NAME=proyekto-backend
OTEL_DEBUG_LOGS=false

# CORS
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
PUBLIC_API_URL=https://api.proyekto.tech

# App links + project invite email delivery
APP_URL=http://localhost:5173
# Optional: if blank, Gmail uses the authenticated mailbox identity.
INVITE_FROM_EMAIL=
# Backward-compatible alias for sender email:
GMAIL_FROM_EMAIL=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# Backward-compatible aliases (if your deployment still uses these names):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Roadmap AI (performance/safety)
ROADMAP_AI_AUTHZ_CACHE_TTL_MS=10000
ROADMAP_AI_AUTHZ_CACHE_MAX_ENTRIES=5000
ROADMAP_AI_AUTHZ_CACHE_VERSION=v1

# Gmail OTP mailer
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_FROM_EMAIL=

# HTTP cache policy tuning (seconds)
CACHE_PUBLIC_MAX_AGE_SECONDS=60
CACHE_PUBLIC_S_MAX_AGE_SECONDS=300
CACHE_PUBLIC_STALE_WHILE_REVALIDATE_SECONDS=60
CACHE_PRIVATE_MAX_AGE_SECONDS=15
CACHE_PRIVATE_STALE_WHILE_REVALIDATE_SECONDS=30

# Upstash Redis (shared for throttling + AI temp store + cache-aside)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Redis data cache tuning
REDIS_DATA_CACHE_ENABLED=true
REDIS_CACHE_PUBLIC_TTL_SECONDS=120
REDIS_CACHE_AUTH_TTL_SECONDS=45
REDIS_CACHE_DEBUG_HEADERS=false
REDIS_CACHE_MARKETPLACE_INDEX_TTL_SECONDS=86400
REDIS_CACHE_TTL_JITTER_PERCENT=10

# Cloudflare edge purge (best-effort, non-blocking)
CLOUDFLARE_PURGE_ENABLED=false
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_PURGE_API_TOKEN=
CLOUDFLARE_PURGE_TIMEOUT_MS=2500

# Realtime (Cloudflare Durable Objects) fan-out — collaborative features only.
# Leave blank to keep the publisher dormant (no-op). When both are set the
# backend POSTs events to the Worker's /publish route.
#   REALTIME_WORKER_URL    deployed Worker origin (e.g. https://proyekto-realtime.<acct>.workers.dev)
#   REALTIME_PUBLISH_TOKEN  shared secret; must match the Worker's secret
REALTIME_WORKER_URL=
REALTIME_PUBLISH_TOKEN=
REALTIME_PUBLISH_TIMEOUT_MS=3000
