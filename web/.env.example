# Web Environment Variables

# Supabase Configuration
VITE_SUPABASE_URL=https://ftuiloyegcipkupbtias.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# API Configuration
VITE_API_URL=http://localhost:3000
VITE_AGENT_API_URL=http://localhost:8010
VITE_AI_PROGRESS_PRESENTATION_MODE=curated

# Realtime Worker (Cloudflare Durable Objects). Origin of the realtime/ Worker.
# Used by the collaborative-feature hooks when their transport flag is set to
# "durable-objects". Leave blank to stay on Supabase Realtime.
VITE_REALTIME_URL=http://localhost:8787

# Upload Worker origin — the Cloudflare Worker that hosts POST /uploads and
# writes files to R2 via a binding. Defaults in code to the deployed realtime
# worker, so this is optional; set it only to point at a local/dev worker.
VITE_UPLOAD_WORKER_URL=

# Playwright Auth QA (optional)
PLAYWRIGHT_BASE_URL=http://localhost:3000
PLAYWRIGHT_AUTH_HEADED=0
PLAYWRIGHT_AUTH_ALLOW_PARTIAL=0
PLAYWRIGHT_AUTH_SETUP_TIMEOUT_MS=600000

# Fallback single-user auth
PLAYWRIGHT_EMAIL=
PLAYWRIGHT_PASSWORD=

# Consultant auth
PLAYWRIGHT_CONSULTANT_EMAIL=
PLAYWRIGHT_CONSULTANT_PASSWORD=

# Freelancer auth
PLAYWRIGHT_FREELANCER_EMAIL=
PLAYWRIGHT_FREELANCER_PASSWORD=
