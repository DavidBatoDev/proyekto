APP_NAME=Roadmap AI Agent
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8010

# NestJS base API URL (include /api prefix)
NEST_API_BASE_URL=http://localhost:8001/api
NEST_TIMEOUT_SECONDS=20

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.3-mini
OPENAI_TEMPERATURE=0.2
OPENAI_REASONING_EFFORT=low
# Output-token ceilings. Each name matches the phase it gates.
# EDIT_* vars govern the edit lane (staging roadmap operations). PLAN_*
# governs the new plan-proposal lane (strategic planning). Legacy aliases
# (OPENAI_MAX_TOKENS, OPENAI_PLANNER_*) still work for one release.
OPENAI_CHAT_MAX_TOKENS=900
OPENAI_EDIT_DEFAULT_MAX_TOKENS=2000
OPENAI_EDIT_REPAIR_MAX_TOKENS=3000
OPENAI_EDIT_NARROW_MAX_TOKENS=800
# Plan-mode phase needs headroom for reasoning tokens PLUS the full JSON
# envelope (summary, goal, rationale, proposed_hierarchy). Clamped to
# [256, 8192]. Don't reuse the chat ceiling here — GPT-5 reasoning models
# burn the budget on hidden reasoning before surfacing text.
OPENAI_PLAN_MAX_TOKENS=4000

# Intent classifier — separate model from the planner. Cheap + fast is
# the goal; we only need a short JSON tag with intent_type + sub_intent.
AGENT_LLM_INTENT_CLASSIFIER_ENABLED=true
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini
OPENAI_CLASSIFIER_MAX_TOKENS=120
OPENAI_CLASSIFIER_TEMPERATURE=0.0

# Agent safety/runtime settings
SESSION_TTL_SECONDS=1800
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_SESSION_KEY_PREFIX=roadmap:ai:session
MAX_OPERATIONS_PER_REQUEST=25
MAX_CHAT_HISTORY_MESSAGES=8
MAX_EDIT_HISTORY_MESSAGES=4
MAX_EDIT_TOOL_TURNS=4
MAX_CONTEXT_TOOL_TURNS=4
MAX_DISCOVERY_TOOL_CALLS=4
MAX_REPEATED_TOOL_CALLS_PER_SIGNATURE=2
# Hard ceiling across all LLM calls in a single user message — prevents a
# runaway react loop from burning the OpenAI quota.
AGENT_MAX_TOTAL_LLM_CALLS_PER_MESSAGE=8
INLINE_PREVIEW_MAX_BYTES=262144
AGENT_CACHE_TTL_SECONDS=600
AGENT_RESOLVE_CACHE_TTL_SECONDS=30
AGENT_RESOLVE_PARALLEL_VARIANTS_ENABLED=false
AGENT_STRICT_MUTATION_AUTHORITY_ENABLED=false
AGENT_HYBRID_REACT_ENABLED=true
AGENT_ASYNC_AUTO_COMMIT_ENABLED=true
# Plan mode: when True the `roadmap_plan` intent produces a structured
# plan proposal (with optional clarifier Q&A) instead of routing straight
# to the edit lane. Flip OFF to roll back to the legacy plan_only flow.
AGENT_PLAN_PROPOSAL_ENABLED=false

AGENT_REACT_REPAIR_RETRIES=1
AGENT_REACT_MAX_ATTEMPTS=2
# Backward-compatible aliases (one release):
# AGENT_EDIT_PLANNER_REPAIR_RETRIES=1
# AGENT_EDIT_PLANNER_MAX_ATTEMPTS=2

# Logging/tracing
AGENT_LOG_LEVEL=DEBUG
AGENT_LOG_JSON=true
AGENT_LOG_COLOR=auto
AGENT_LOG_INCLUDE_CONTENT=false
AGENT_PROGRESS_EVENTS_ENABLED=true
AGENT_PROGRESS_EVENTS_ALLOW_VERBOSE=true
