APP_NAME=Roadmap AI Agent
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8010

# NestJS base API URL (include /api prefix)
NEST_API_BASE_URL=http://localhost:8001/api
NEST_TIMEOUT_SECONDS=90

# OpenAI
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# v2 single-loop agent (app/core/v2) — the only roadmap-AI brain.
# AgentService.plan_message runs the lean hand-rolled tool-calling loop on ONE
# model (no separate classifier). gpt-5.4-mini is the cost/quality sweet spot;
# gpt-5.4-nano is cheapest, gpt-5.4 (full) for hard cases.
# ---------------------------------------------------------------------------
OPENAI_MODEL_V2=gpt-5.4-mini
AGENT_V2_MAX_TURNS=8
AGENT_V2_MAX_TOOL_CALLS=14
OPENAI_V2_MAX_OUTPUT_TOKENS=4000
OPENAI_V2_REASONING_EFFORT=low
# Omit (leave blank) for GPT-5 reasoning models — they reject non-default
# temperature. Set a float only if your configured model accepts it.
# OPENAI_V2_TEMPERATURE=
# Stream model calls so the web can render assistant text as it generates
# (via assistant_delta trace events). false = plain non-streaming calls.
OPENAI_V2_STREAMING_ENABLED=true

# Agent runtime settings
SESSION_TTL_SECONDS=14400
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_SESSION_KEY_PREFIX=roadmap:ai:session
MAX_OPERATIONS_PER_REQUEST=25
# Counts include structured tool-call pairs (role='assistant' with
# tool_calls + role='tool' with tool_call_id). 1 resolver call = 2
# messages; a typical edit turn produces 4-10 messages total.
MAX_CHAT_HISTORY_MESSAGES=30
# Conversation compaction: past TRIGGER messages the oldest turns beyond
# KEEP are folded into a rolling summary (computed on SUMMARY_MODEL,
# applied at the next turn start) and truncated from Redis.
AGENT_SUMMARY_MODEL=gpt-4o-mini
AGENT_SUMMARY_TRIGGER_MESSAGES=40
AGENT_SUMMARY_KEEP_MESSAGES=30
AGENT_SUMMARY_MAX_CHARS=4000
# Synchronous commit (false): keeps overview/handle-map fresh for the next
# turn so follow-up rename/delete target the right node. true = faster
# response but races the next turn against stale state.
AGENT_ASYNC_AUTO_COMMIT_ENABLED=false
AGENT_CACHE_TTL_SECONDS=600
# Resolve-lookup cache lives only for one message turn (the dispatcher is
# rebuilt per turn). 300 (the max) keeps a resolved node cached for the whole
# turn so long multi-tool turns don't re-hit the DB for a label they already
# resolved. Capped at 300.
AGENT_RESOLVE_CACHE_TTL_SECONDS=300
AGENT_RESOLVE_PARALLEL_VARIANTS_ENABLED=false

# Logging/tracing
AGENT_LOG_LEVEL=DEBUG
AGENT_LOG_JSON=true
AGENT_LOG_COLOR=auto
AGENT_LOG_INCLUDE_CONTENT=false
# When set, every event is written to this file in append mode. ANSI colors
# are always disabled when a file handler is attached. Leave unset (or blank)
# to log only to the terminal.
# AGENT_LOG_FILE=../logs.txt
# Disable terminal logging when AGENT_LOG_FILE is set to route output to the
# file only. Defaults to true; set to false to silence stdout/stderr.
AGENT_LOG_TO_CONSOLE=true
AGENT_PROGRESS_EVENTS_ENABLED=true
AGENT_PROGRESS_EVENTS_ALLOW_VERBOSE=true
