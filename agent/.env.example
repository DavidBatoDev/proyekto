APP_NAME=Roadmap AI Agent
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8010

# NestJS base API URL (include /api prefix)
NEST_API_BASE_URL=http://localhost:8001/api
NEST_TIMEOUT_SECONDS=20

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_TEMPERATURE=0.2

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_RETRIES=0

# Provider routing
LLM_PRIMARY_PROVIDER=gemini
LLM_FALLBACK_PROVIDER=openai

# Agent safety/runtime settings
SESSION_TTL_SECONDS=1800
MAX_OPERATIONS_PER_REQUEST=25
MAX_CHAT_HISTORY_MESSAGES=8
MAX_EDIT_TOOL_TURNS=2
MAX_CONTEXT_TOOL_TURNS=1
AGENT_QUOTA_DAILY_LIMIT=20
AGENT_CACHE_TTL_SECONDS=600

# Logging/tracing
AGENT_LOG_LEVEL=DEBUG
AGENT_LOG_JSON=true
AGENT_LOG_INCLUDE_CONTENT=false
AGENT_LOW_QUOTA_MODE=true
